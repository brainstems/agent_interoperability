# Database - Supabase Integration
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
# Alternative direct connection (if using connection pooling)
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"

# Supabase Configuration
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Multi-Codebase Integration URLs
NEXT_PUBLIC_EMBARK2_ERIC_URL="http://localhost:3001"
NEXT_PUBLIC_SPARK_FELLOWSHIP_URL="http://localhost:3002"
NEXT_PUBLIC_VOCAL_CONNECT_URL="http://localhost:3003"
NEXT_PUBLIC_WINDSURF_PROJECT_URL="http://localhost:3000"

# Authentication
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-here"

# Email Services
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@yourchurch.org"

# SMS Services
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="your-twilio-phone-number"

# Payment Processing
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# File Storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Background Checks
VERIFIED_FIRST_API_KEY="your-verified-first-api-key"
VERIFIED_FIRST_API_URL="https://api.verifiedfirst.com"

# AI Services (Optional)
OPENAI_API_KEY="your-openai-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Application Settings
NODE_ENV="development"
PORT=3000
